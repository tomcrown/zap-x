# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Privy (get from https://dashboard.privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Starknet
STARKNET_NETWORK=sepolia
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Escrow / Treasury Wallet (server-side signing for escrow)
ESCROW_WALLET_ADDRESS=0xYourEscrowWalletAddress
ESCROW_PRIVATE_KEY=0xYourEscrowPrivateKey

# AVNU Paymaster (get from https://portal.avnu.fi)
AVNU_PAYMASTER_URL=https://sepolia.paymaster.avnu.fi
AVNU_API_KEY=your_avnu_api_key

# Staking Pool Addresses (Starknet STRK staking pool)
STRK_STAKING_POOL=0x03745ab04a431fc02871a139be6b93d9260b0ff3e779ad9c8b377183b23109f1

# Gemini AI (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Zap-X <noreply@zapx.app>"

# Database
DB_PATH=./data/zapx.db
